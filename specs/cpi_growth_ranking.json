{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Horizontal bar chart ranking states by post-2020 CPI index-point growth.",
  "width": "container",
  "height": 330,
  "data": { "url": "../data/cpi_2d_state.csv" },
  "transform": [
    { "filter": "datum.division == 'overall'" },
    { "filter": "datum.date >= '2020-01-01'" },
    {
      "window": [
        { "op": "first_value", "field": "index", "as": "start_index" },
        { "op": "last_value", "field": "index", "as": "latest_index" },
        { "op": "first_value", "field": "date", "as": "start_date" },
        { "op": "last_value", "field": "date", "as": "latest_date" }
      ],
      "frame": [null, null],
      "sort": [{ "field": "date", "order": "ascending" }],
      "groupby": ["state"]
    },
    { "window": [{ "op": "rank", "as": "latest_row" }], "sort": [{ "field": "date", "order": "descending" }], "groupby": ["state"] },
    { "filter": "datum.latest_row == 1" },
    { "calculate": "toNumber(datum.latest_index) - toNumber(datum.start_index)", "as": "growth_index" },
    { "calculate": "(toNumber(datum.latest_index) - toNumber(datum.start_index)) / toNumber(datum.start_index) * 100", "as": "growth_pct" },
    { "window": [{ "op": "rank", "as": "growth_rank" }], "sort": [{ "field": "growth_index", "order": "descending" }] }
  ],
  "layer": [
    {
      "mark": { "type": "bar", "cornerRadiusEnd": 2 },
      "encoding": {
        "y": { "field": "state", "type": "nominal", "sort": { "field": "growth_index", "order": "descending" } },
        "x": { "field": "growth_index", "type": "quantitative", "title": "CPI increase since 2020, index points" },
        "color": { "condition": { "test": "datum.growth_rank <= 5", "value": "#1d1d1f" }, "value": "#e5e5e7" },
        "tooltip": [
          { "field": "state", "type": "nominal" },
          { "field": "growth_index", "type": "quantitative", "format": ".1f" },
          { "field": "growth_pct", "type": "quantitative", "format": ".1f" }
        ]
      }
    },
    {
      "mark": { "type": "text", "align": "left", "baseline": "middle", "dx": 8, "fontSize": 10, "fontWeight": 600, "color": "#6e6e73" },
      "encoding": {
        "y": { "field": "state", "type": "nominal", "sort": { "field": "growth_index", "order": "descending" } },
        "x": { "field": "growth_index", "type": "quantitative" },
        "text": { "field": "growth_index", "type": "quantitative", "format": ".1f" }
      }
    }
  ],
  "title": { "text": "Growth ranking", "subtitle": "Index-point increase since 2020.", "anchor": "start" }
}
