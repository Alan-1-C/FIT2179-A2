{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Horizontal bar chart using a derived composite pressure index. JavaScript joins CPI and HIES data, min-max scales CPI growth, expenditure burden, and poverty, then averages the three scores.",
  "width": "container",
  "height": 440,
  "data": {
    "name": "derived_pressure_index_rows",
    "description": "Rows contain state, growth_index, expenditure_share, poverty, pressure_index, and pressure_rank."
  },
  "layer": [
    {
      "mark": { "type": "bar", "cornerRadiusEnd": 2 },
      "encoding": {
        "y": { "field": "state", "type": "nominal", "sort": { "field": "pressure_index", "order": "descending" } },
        "x": { "field": "pressure_index", "type": "quantitative", "title": "Final cost pressure index (0-100)", "scale": { "domain": [0, 100] } },
        "color": { "condition": { "test": "datum.pressure_rank <= 3", "value": "#1d1d1f" }, "value": "#e5e5e7" },
        "tooltip": [
          { "field": "state", "type": "nominal" },
          { "field": "growth_index", "type": "quantitative", "format": ".1f" },
          { "field": "expenditure_share", "type": "quantitative", "format": ".1f" },
          { "field": "poverty", "type": "quantitative", "format": ".1f" },
          { "field": "pressure_index", "type": "quantitative", "format": ".1f" }
        ]
      }
    },
    {
      "mark": { "type": "text", "align": "left", "baseline": "middle", "dx": 8, "fontSize": 10, "fontWeight": 700, "color": "#1d1d1f" },
      "encoding": {
        "y": { "field": "state", "type": "nominal", "sort": { "field": "pressure_index", "order": "descending" } },
        "x": { "field": "pressure_index", "type": "quantitative" },
        "text": { "field": "pressure_index", "type": "quantitative", "format": ".0f" }
      }
    }
  ],
  "title": { "text": "Pressure index", "subtitle": "Composite state ranking.", "anchor": "start" }
}
