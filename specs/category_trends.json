{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Small multiples showing CPI trends for selected key categories in a selected state.",
  "data": { "url": "../data/cpi_2d_state.csv" },
  "params": [
    {
      "name": "selectedState",
      "value": "Selangor",
      "bind": {
        "input": "select",
        "name": "Selected State",
        "options": [
          "Johor", "Kedah", "Kelantan", "Melaka", "Negeri Sembilan", "Pahang",
          "Perak", "Perlis", "Pulau Pinang", "Sabah", "Sarawak", "Selangor",
          "Terengganu", "W.P. Kuala Lumpur", "W.P. Labuan", "W.P. Putrajaya"
        ]
      }
    }
  ],
  "transform": [
    { "calculate": "toString(datum.division)", "as": "division_code" },
    { "calculate": "datum.division_code == '1' ? 'Food' : datum.division_code == '4' ? 'Housing' : datum.division_code == '7' ? 'Transport' : datum.division_code == '11' ? 'Restaurants' : 'Other'", "as": "division_short" },
    { "filter": "datum.division_short != 'Other'" },
    { "filter": "datum.state == selectedState" }
  ],
  "facet": { "field": "division_short", "type": "nominal", "sort": ["Food", "Housing", "Transport", "Restaurants"] },
  "columns": 2,
  "spec": {
    "width": 360,
    "height": 180,
    "mark": { "type": "line", "strokeWidth": 2, "color": "#1d1d1f" },
    "encoding": {
      "x": { "field": "date", "type": "temporal", "axis": { "format": "%Y", "labelAngle": 0 } },
      "y": { "field": "index", "type": "quantitative", "scale": { "zero": false } },
      "tooltip": [
        { "field": "state", "type": "nominal" },
        { "field": "division_short", "type": "nominal" },
        { "field": "date", "type": "temporal", "format": "%b %Y" },
        { "field": "index", "type": "quantitative", "format": ".1f" }
      ]
    }
  },
  "resolve": { "scale": { "y": "independent" } },
  "title": { "text": "Category trends", "subtitle": "Selected state, key categories.", "anchor": "start" }
}
